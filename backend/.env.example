# ══════════════════════════════════════════
# GOAT Turf Backend — Environment Variables
# ══════════════════════════════════════════
# Copy this file to .env and fill in your real keys

# ── Server ──
PORT=5000
FRONTEND_URL=https://your-production-frontend-url.com

# ── Supabase ──
SUPABASE_URL=https://example.supabase.co
SUPABASE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay ──
# 🟡 Test Mode Keys
RAZORPAY_KEY_ID_TEST=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET_TEST=your_test_key_secret

# 🟢 Live Mode Keys
RAZORPAY_KEY_ID_LIVE=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET_LIVE=your_live_key_secret

# ⚙️ ACTIVE KEYS
# Copy your chosen Key ID and Secret (Test or Live) here
# By default, we are preparing for the test mode
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_key_secret

# ── Pricing (INR per hour) ──
PRICE_PER_HOUR_CRICKET=1000
PRICE_PER_HOUR_FOOTBALL=1000
